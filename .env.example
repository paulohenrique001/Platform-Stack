STACK_NAME=dockge-platform
TZ=America/Sao_Paulo
RESTART_POLICY=unless-stopped

PLATFORM_NETWORK_NAME=dockge_platform_network

DOCKGE_CONTAINER_NAME=dockge-dockge
DOCKGE_ENABLE_CONSOLE=true
DOCKGE_PORT=5001
DOCKGE_STACKS_PATH=./stacks
DOCKGE_DATA_VOLUME_NAME=dockge_dockge_data

DOZZLE_CONTAINER_NAME=dockge-dozzle
DOZZLE_PORT=8080

UPTIME_KUMA_CONTAINER_NAME=dockge-uptime-kuma
UPTIME_KUMA_PORT=3001
UPTIME_KUMA_DATA_VOLUME_NAME=dockge_uptime_kuma_data
